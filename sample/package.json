{
  "private": true,
  "name": "sample",
  "type": "module",
  "scripts": {
    "emit": "tsp compile . && node patch-generated.cjs",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "node --import tsx server.ts",
    "open:bruno": "open -a Bruno collection",
    "test:api": "cd collection && bru run --env Local -r"
  },
  "dependencies": {
    "@typespec/compiler": "catalog:default",
    "@typespec/http": "catalog:default",
    "@typespec/openapi": "catalog:default",
    "@typespec/openapi3": "catalog:default",
    "@typespec/http-server-js": "catalog:default",
    "typespec-opencollection": "workspace:*",
    "typespec-random-sample": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:default",
    "@usebruno/cli": "^3.2.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:default"
  }
}
